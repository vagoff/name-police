#!/bin/bash
if [ ! -f "scripts/gen-index.js" ]; then
  echo "pre-push: scripts/gen-index.js not found, skipping"
  exit 0
fi

node scripts/gen-index.js

if git diff --quiet INDEX.md; then
  exit 0
fi

echo "pre-push: INDEX.md updated, amending last commit..."
git add INDEX.md
git commit --amend --no-edit --quiet
