#!/bin/bash
# pre-commit: structural check + naming check + index rebuild

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.js$')

if [ -z "$STAGED" ]; then
    exit 0
fi

ERRORS=0

# --- lex-police ---
echo "lex-police: checking structural conventions..."
node lex-police/index.js $STAGED
if [ $? -ne 0 ]; then
    ERRORS=1
fi

# --- name-police ---
if [ -f ".name-police.json" ]; then
    echo "name-police: checking naming conventions..."
    node src/checker.js .name-police.json $STAGED
    if [ $? -ne 0 ]; then
        ERRORS=1
    fi
fi

if [ $ERRORS -ne 0 ]; then
    echo ""
    echo "✗ Commit blocked. Fix violations above."
    exit 1
fi

# --- build index (only if checks passed) ---
ALL_JS=$(git ls-files '*.js')
if [ -n "$ALL_JS" ]; then
    echo "build-index: rebuilding CODEBASE-INDEX.json..."
    node lex-police/build-index.js $ALL_JS --out CODEBASE-INDEX.json
    if [ $? -eq 0 ] && ! git diff --quiet CODEBASE-INDEX.json; then
        git add CODEBASE-INDEX.json
        echo "build-index: CODEBASE-INDEX.json staged."
    fi
fi

exit 0
